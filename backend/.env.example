# Comma-separated list of valid API keys (required)
API_KEYS=change-me

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=3600

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Max upload size in bytes (default 4 GB)
# MAX_UPLOAD_SIZE=4294967296

# Contribute feature — the VS server map ID shown to users
CONTRIBUTE_MAP_ID=48bd1c98-4ee0-414a-b584-a3628278d99d


# Admin API key for approving/rejecting contributions (required for admin actions)
ADMIN_API_KEY=change-me-admin

# Secret salt for hashing IP addresses before storage (GDPR compliance).
# Set to a long random string. Changing this invalidates existing consume_once key bindings.
IP_HASH_SALT=change-me-to-a-long-random-secret

# Cloudflare R2 (S3-compatible object storage for .db files)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=vs-waypoints

# Supabase PostgreSQL connection string
SUPABASE_DB_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
