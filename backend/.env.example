# Comma-separated list of valid API keys (required)
API_KEYS=change-me

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=3600

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Max upload size in bytes (default 4 GB)
# MAX_UPLOAD_SIZE=4294967296

# Contribute feature — the VS server map ID shown to users
CONTRIBUTE_MAP_ID=48bd1c98-4ee0-414a-b584-a3628278d99d


# Admin API key for approving/rejecting contributions (required for admin actions)
ADMIN_API_KEY=change-me-admin

# Secret salt for hashing IP addresses before storage (GDPR compliance).
# Set to a long random string. Changing this invalidates existing consume_once key bindings.
IP_HASH_SALT=change-me-to-a-long-random-secret

# Cloudflare R2 (S3-compatible object storage for .db files)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=vs-waypoints

# Supabase PostgreSQL connection string
SUPABASE_DB_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# --- Phase 3: public contribution history ---
# Recent Contributions grid previews are kept forever. The values below
# control only the lifetime of the per-contribution archived .db file in R2
# (used to power per-contribution revert). Non-admin uploads use the shorter
# retention; admin uploads use the longer one.
# HISTORY_RETENTION_DAYS=14
# ADMIN_HISTORY_RETENTION_DAYS=90
# Anti-spam cap on owner-initiated withdrawals per ISO calendar week.
# WITHDRAW_LIMIT_PER_WEEK=3
# Background sweeper cadence for expiring archived .db files (preview PNGs
# are not affected — they are kept forever).
# HISTORY_CLEANUP_INTERVAL_SECONDS=86400

# --- Phase 4a: weekly backups + TOTP-gated restore ---
# Symmetric Fernet key used to encrypt admin TOTP secrets at rest. REQUIRED to
# enable TOTP enrolment and the restore endpoint. Without it those endpoints
# return 503 totp_not_configured. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=
# Label shown in the user's authenticator app (Google Authenticator, etc.).
# TOTP_ISSUER=Cairn Admin
# How many of each kind of backup to keep in R2 (cleanup is application-side).
# BACKUP_KEEP_SCHEDULED=4
# BACKUP_KEEP_MANUAL=8
# How often the backup scheduler thread wakes up to check whether a new ISO
# week has begun. Hourly is plenty — a snapshot fires at most once per week.
# BACKUP_CHECK_INTERVAL_SECONDS=3600


# --- Phase 4c: admin WebAuthn (passkey 2FA) ---
# When configured, admins are required to verify a registered passkey
# (Windows Hello / Touch ID / hardware key / password manager) after pasting
# their admin API key. The passkey signs a server-issued challenge; the
# server then mints a short-lived X-Admin-Session token bound to the client
# IP hash. Without WEBAUTHN_RP_ID set, all /admin/webauthn/* endpoints
# return 503 webauthn_not_configured and the gate is effectively disabled.
# See docs/users/admin-webauthn.md for the full reference.
#
# The Relying Party ID. Must match the public hostname the frontend is
# served from (no scheme, no port). Use "localhost" for local dev.
# WEBAUTHN_RP_ID=vs-waypoints.example.com
# Human-readable name shown in the OS / browser passkey prompt.
# WEBAUTHN_RP_NAME=Cairn Admin
# Comma-separated allow-list of full origins (scheme + host + optional port)
# permitted to register / assert. Falls back to ALLOWED_ORIGINS if unset.
# WEBAUTHN_ORIGINS=https://vs-waypoints.example.com,http://localhost:5173
# Lifetime of the X-Admin-Session token issued after a successful assertion.
# Tokens live in process memory only — restarting the API forces re-verification.
# WEBAUTHN_SESSION_TTL_SECONDS=28800
# When True (default), admins with at least one registered passkey MUST
# present a valid X-Admin-Session header on every /api/admin/* call. Set to
# False during initial rollout to make passkey verification purely optional.
# WEBAUTHN_ENFORCE=True


# --- Phase 4b: per-contribution revert ---
# How many days after approval a contribution can still be reverted. Beyond
# the window, the only undo path is restoring a Phase-4a weekly backup.
# REVERT_WINDOW_DAYS=14
# Hard cap on the per-contribution undo blob in object storage. Each entry is
# 8 bytes (little-endian uint64), so the default 64 MiB == ~8M positions.
# Contributions whose merge would exceed the cap are flagged
# revert_supported = false and can only be reverted via a backup restore.
# REVERT_ADDED_BIN_MAX_BYTES=67108864

# --- Phase 2: region-restricted updates ---
# When a contributor selects a rectangular region, in-region tiles are
# overwritten on approval (instead of the legacy gap-fill behaviour). This
# feature is gated behind:
#   - the `region_overwrite` feature flag (admin-toggleable in the UI), and
#   - either admin status or the per-key `region_overwrite` permission.
# Non-admin contributors are additionally capped at this many tiles in a
# single region. Default 65536 == a 256x256 tile area == 8192x8192 blocks.
# Admins are not subject to this cap.
# MAX_REGION_TILES_NON_ADMIN=65536

TOPS_MAP_PARALLEL_REGEN=true
