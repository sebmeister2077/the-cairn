     <table:table-cell table:style-name="price-cell" table:formula="of:=ROUND(MAX(1;[.$B$4]*(1+LN(MAX([.F25];0.0000001))))*[.$B$6];0)" office:value-type="float" office:value="35" calcext:value-type="float">
      <text:p>35</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="price-cell" table:formula="of:=ROUND([.$B$4]*[.F25]*[.$B$7];0)" office:value-type="float" office:value="416" calcext:value-type="float">
      <text:p>416</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="price-cell" table:formula="of:=ROUND([.$B$4]*SQRT([.F25])*[.$B$7];0)" office:value-type="float" office:value="100" calcext:value-type="float">
      <text:p>100</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="price-cell" table:formula="of:=ROUND(MAX(1;[.$B$4]*(1+LN(MAX([.F25];0.0000001))))*[.$B$7];0)" office:value-type="float" office:value="92" calcext:value-type="float">
      <text:p>92</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="5"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="Default"/>
     <table:table-cell/>
     <table:table-cell table:style-name="Default" table:number-columns-repeated="3"/>
     <table:table-cell table:number-columns-repeated="15"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string">
      <text:p>Total</text:p>
     </table:table-cell>
     <table:table-cell/>
     <table:table-cell table:formula="of:=SUM([.C13:.C25])" office:value-type="float" office:value="4000000" calcext:value-type="float">
      <text:p>4,000,000</text:p>
     </table:table-cell>
     <table:table-cell table:formula="of:=SUM([.D13:.D25])" office:value-type="float" office:value="7346816" calcext:value-type="float">
      <text:p>7,346,816</text:p>
     </table:table-cell>
     <table:table-cell table:formula="of:=SUM([.E13:.E25])" office:value-type="percentage" office:value="1" calcext:value-type="percentage">
      <text:p>100.00%</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="15"/>
    </table:table-row>
   </table:table>
   <table:table table:name="How to use" table:style-name="ta1">
    <table:table-column table:style-name="co18" table:number-columns-repeated="2" table:default-cell-style-name="Default"/>
    <table:table-row table:style-name="ro1">
     <table:table-cell table:style-name="ce3" office:value-type="string" calcext:value-type="string">
      <text:p>How to use this sheet</text:p>
     </table:table-cell>
     <table:table-cell/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:number-columns-repeated="2"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>1. Open the &quot;Prices&quot; sheet.</text:p>
     </table:table-cell>
     <table:table-cell/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>2. Edit yellow cells B4:B7 to change base price, igneous boost, and variant multipliers.</text:p>
     </table:table-cell>
     <table:table-cell/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>3. Three rarity curves are shown side-by-side; pick the one that feels right for your economy.</text:p>
     </table:table-cell>
     <table:table-cell/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>4. Re-run generate_prices_fods.ts whenever the rockmap JSON changes.</text:p>
     </table:table-cell>
     <table:table-cell/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:number-columns-repeated="2"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string">
      <text:p>Curve definitions (let r = granite_boosted% / rock_boosted%)</text:p>
     </table:table-cell>
     <table:table-cell/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Linear:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>price = base * r <text:s text:c="11"/>(true inverse rarity, biggest spread)</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Sqrt:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>price = base * SQRT(r) <text:s text:c="5"/>(gentler, recommended)</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Log:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>price = base * (1 + LN(r)) <text:s/>(very compressed; clamped to min 1)</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:number-columns-repeated="2"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce6" office:value-type="string" calcext:value-type="string">
      <text:p>Variants</text:p>
     </table:table-cell>
     <table:table-cell/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Ashlar:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>price as computed by curve</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Polished:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>ashlar curve × Polished multiplier (default 3)</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Cracked/Tiles:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>ashlar curve × Cracked multiplier (default 6 = 2× polished)</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
